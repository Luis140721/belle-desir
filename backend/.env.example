# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/belle_desir

# JWT
JWT_SECRET=minimo_32_caracteres_aleatorios
JWT_EXPIRES_IN=7d

# Servidor
PORT=3001
NODE_ENV=development

# CORS - Orígenes permitidos
FRONTEND_URL=https://tu-dominio.com
ADMIN_URL=https://admin.tu-dominio.com

# Bold Colombia - Pagos
# Obtener en: panel.bold.co -> Integraciones -> API
BOLD_API_KEY=
BOLD_INTEGRITY_SECRET=

# Email Service - Resend
# Obtener en: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@belledesir.com

# Cloudinary - Storage de imágenes
# Obtener en: https://cloudinary.com/console -> Dashboard -> Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Variables adicionales
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STORAGE_PROVIDER=cloudinary
